{
  "manifest_version": 3,
  "name": "MCP Multi Bridge",
  "version": "1.0.0",
  "description": "Connect multiple MCP servers to web-based AI assistants (ChatGPT, Gemini, DeepSeek, Grok, etc.)",
  "permissions": [
    "storage",
    "nativeMessaging",
    "sidePanel",
    "tabs"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*",
        "https://www.perplexity.ai/*",
        "https://aistudio.google.com/*",
        "https://chat.mistral.ai/*",
        "https://t3.chat/*",
        "https://chat.qwen.ai/*",
        "https://qianwen.com/*",
        "https://www.qianwen.com/*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://chatglm.cn/*",
        "https://chat.z.ai/*",
        "https://github.com/copilot*",
        "https://www.doubao.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "MCP Multi Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.css", "dragDropListener.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
